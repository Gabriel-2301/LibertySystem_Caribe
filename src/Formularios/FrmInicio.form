        <Container class="javax.swing.JDesktopPane" name="jDesktopPanel">
          <AuxValues>
            <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JDesktopPane() {&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        super.paintComponent(g);&#xa;&#xa;        java.net.URL url = getClass().getResource(&quot;/IMG/LIBERTY_NETWORKS_MAP.png&quot;);&#xa;        if (url != null) {&#xa;            java.awt.Image img = new javax.swing.ImageIcon(url).getImage();&#xa;&#xa;            // Convertimos a Graphics2D para aplicar filtros avanzados de calidad de imagen&#xa;            java.awt.Graphics2D g2d = (java.awt.Graphics2D) g;&#xa;&#xa;            // FILTROS DE ALTA CALIDAD: Evitan que la imagen se pixele o se vea borrosa al estirarse&#xa;            g2d.setRenderingHint(java.awt.RenderingHints.KEY_INTERPOLATION, java.awt.RenderingHints.VALUE_INTERPOLATION_BICUBIC);&#xa;            g2d.setRenderingHint(java.awt.RenderingHints.KEY_RENDERING, java.awt.RenderingHints.VALUE_RENDER_QUALITY);&#xa;            g2d.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xa;            g2d.setRenderingHint(java.awt.RenderingHints.KEY_COLOR_RENDERING, java.awt.RenderingHints.VALUE_COLOR_RENDER_QUALITY);&#xa;&#xa;            // Dibujamos la imagen forz&#xe1;ndola a rellenar el 100% del panel (0, 0, ancho, alto)&#xa;            g2d.drawImage(img, 0, 0, getWidth(), getHeight(), this);&#xa;        }&#xa;    }&#xa;};&#xa;"/>
          </AuxValues>

